{
  "name": "obsidian-zotero-mirror",
  "version": "0.4.9",
  "description": "Auto-import Zotero annotations into Obsidian by driving the Zotero Integration plugin.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck"
  },
  "keywords": ["obsidian", "zotero", "annotations"],
  "author": "Derek Tam",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.20.2",
    "obsidian": "latest",
    "typescript": "^5.4.0"
  }
}
